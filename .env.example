# Craftista Application Environment Configuration
# Copy this file to .env and update the values for your environment

# Application Versions
FRONTEND_VERSION=v1
CATALOGUE_VERSION=v1
VOTING_VERSION=v1
RECCO_VERSION=v1

# Environment Configuration
NODE_ENV=production
FLASK_ENV=production
SPRING_PROFILES_ACTIVE=production
GIN_MODE=release

# MongoDB Configuration
MONGODB_ROOT_USERNAME=admin
MONGODB_ROOT_PASSWORD=admin123
MONGODB_DATABASE=catalogue
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=2
MONGODB_CONNECTION_TIMEOUT_MS=20000
MONGODB_RETRY_ATTEMPTS=3

# PostgreSQL Configuration
POSTGRES_DB=voting
POSTGRES_USER=voting_user
POSTGRES_PASSWORD=voting_pass
DATABASE_MAX_CONNECTIONS=10
DATABASE_CONNECTION_TIMEOUT=20000
DATABASE_RETRY_ATTEMPTS=3

# Redis Configuration
REDIS_DATABASE=0
REDIS_MAX_MEMORY=256mb
REDIS_MAX_RETRIES=3
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=2
CACHE_DEFAULT_TTL=1h

# Application Configuration
DATA_SOURCE=mongodb
HEALTH_CHECK_ENABLED=true
FLYWAY_ENABLED=true

# Logging Configuration
CATALOGUE_LOG_LEVEL=INFO
VOTING_LOG_LEVEL=INFO
RECOMMENDATION_LOG_LEVEL=info

# Service URLs (for internal communication)
CATALOGUE_SERVICE_URL=http://catalogue:5000/api/products
PRODUCTS_API_BASE_URI=http://catalogue:5000
RECOMMENDATION_BASE_URI=http://recco:8080
VOTING_BASE_URI=http://voting:8080