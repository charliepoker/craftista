{
  "name": "craftista-frontend",
  "version": "1.0.0",
  "main": "app.js",
  "dependencies": {
    "axios": "^0.21.1",
    "dependencies": "^0.0.1",
    "ejs": "^3.1.6",
    "express": "^4.17.1"
  },
  "scripts": {
    "start": "node app.js",
    "dev": "node app.js",
    "test": "mocha test/*.js",
    "test:unit": "mocha test/appTest.js",
    "test:integration": "mocha test/integration/*.js",
    "test:performance": "mocha test/performance/*.js --timeout 60000",
    "test:coverage": "nyc --reporter=lcov --reporter=text --report-dir=./coverage mocha 'test/**/*.js'",
    "test:coverage:ci": "nyc --reporter=lcov --reporter=text --report-dir=./coverage mocha 'test/**/*.js' --exclude 'test/performance/**'",
    "lint": "eslint ."
  },
  "devDependencies": {
    "chai": "^4.3.10",
    "chai-http": "^4.3.0",
    "eslint": "^9.19.0",
    "globals": "^13.24.0",
    "mocha": "^10.2.0",
    "nock": "^13.3.4",
    "nyc": "^15.1.0"
  },
  "nyc": {
    "all": true,
    "include": [
      "routes/**/*.js",
      "app.js"
    ],
    "exclude": [
      "test/**/*.js",
      "coverage/**"
    ],
    "reporter": [
      "lcov",
      "text"
    ],
    "report-dir": "./coverage",
    "cache": false,
    "sourceMap": true
  }
}
