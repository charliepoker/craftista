# Recommendation Service Environment Configuration
# Copy this file to .env and update the values for your environment

# Application Configuration
APP_VERSION=1.0.0
GIN_MODE=release
PORT=8080

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# Redis Connection Pool Configuration
REDIS_MAX_RETRIES=3
REDIS_MIN_RETRY_BACKOFF=8ms
REDIS_MAX_RETRY_BACKOFF=512ms
REDIS_DIAL_TIMEOUT=5s
REDIS_READ_TIMEOUT=3s
REDIS_WRITE_TIMEOUT=3s
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=2
REDIS_MAX_CONN_AGE=30m
REDIS_POOL_TIMEOUT=4s
REDIS_IDLE_TIMEOUT=5m
REDIS_IDLE_CHECK_FREQUENCY=1m

# Cache Configuration
CACHE_DEFAULT_TTL=1h
CACHE_ORIGAMI_DAILY_TTL=24h
CACHE_RECOMMENDATIONS_TTL=1h

# Recommendation Algorithm Configuration
RECOMMENDATION_DEFAULT_LIMIT=5
RECOMMENDATION_MAX_LIMIT=20
RECOMMENDATION_SCORE_MIN=0
RECOMMENDATION_SCORE_MAX=10

# Health Check Configuration
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30s

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

# Security Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
API_RATE_LIMIT=100

# Performance Configuration
READ_TIMEOUT=30s
WRITE_TIMEOUT=30s
IDLE_TIMEOUT=120s
MAX_HEADER_BYTES=1048576