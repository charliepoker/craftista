# Voting Service Environment Configuration
# Copy this file to .env and update the values for your environment

# Application Configuration
APP_VERSION=1.0.0
SPRING_PROFILES_ACTIVE=production

# Database Configuration
DATABASE_URL=jdbc:postgresql://localhost:5432/voting
DATABASE_USERNAME=voting_user
DATABASE_PASSWORD=voting_pass
DATABASE_MAX_CONNECTIONS=10
DATABASE_MIN_IDLE=5
DATABASE_CONNECTION_TIMEOUT=20000
DATABASE_IDLE_TIMEOUT=300000
DATABASE_MAX_LIFETIME=1200000
DATABASE_LEAK_DETECTION_THRESHOLD=60000

# Database Retry Configuration
DATABASE_RETRY_ATTEMPTS=3
DATABASE_RETRY_DELAY=1000
DATABASE_RETRY_MULTIPLIER=2.0

# Circuit Breaker Configuration
CIRCUIT_BREAKER_FAILURE_RATE=50
CIRCUIT_BREAKER_WAIT_DURATION=30000
CIRCUIT_BREAKER_SLIDING_WINDOW=10

# JPA Configuration
JPA_DDL_AUTO=validate
JPA_SHOW_SQL=false

# Flyway Configuration
FLYWAY_ENABLED=true

# Catalogue Service Integration
CATALOGUE_SERVICE_URL=http://catalogue:5000/api/products
CATALOGUE_SYNC_INTERVAL=60000

# Logging Configuration
LOG_LEVEL=INFO
WEB_LOG_LEVEL=WARN
SQL_LOG_LEVEL=WARN
SQL_PARAM_LOG_LEVEL=WARN

# Actuator Configuration
MANAGEMENT_ENDPOINTS_ENABLED=health,info,metrics,prometheus

# Security Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Performance Configuration
SERVER_TOMCAT_MAX_THREADS=200
SERVER_TOMCAT_MIN_SPARE_THREADS=10