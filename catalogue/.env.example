# Catalogue Service Environment Configuration
# Copy this file to .env and update the values for your environment

# Application Configuration
APP_VERSION=1.0.0
FLASK_DEBUG=false
FLASK_ENV=production

# Data Source Configuration
# Options: "json" or "mongodb"
DATA_SOURCE=mongodb

# MongoDB Configuration
MONGODB_URL=mongodb://catalogue_user:catalogue_pass@localhost:27017/catalogue
MONGODB_DATABASE=catalogue
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=2
MONGODB_MAX_IDLE_TIME_MS=30000
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
MONGODB_CONNECTION_TIMEOUT_MS=20000
MONGODB_RETRY_ATTEMPTS=3
MONGODB_RETRY_DELAY=1.0

# Legacy PostgreSQL Configuration (for backward compatibility)
DB_HOST=localhost
DB_NAME=catalogue
DB_USER=catalogue_user
DB_PASSWORD=catalogue_pass

# Health Check Configuration
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Security Configuration
SECRET_KEY=your-secret-key-here
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Performance Configuration
MAX_CONTENT_LENGTH=16777216  # 16MB
REQUEST_TIMEOUT=30